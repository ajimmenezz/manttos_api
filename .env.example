APP_NAME="Sistema de Mantenimientos"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-dominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_MX

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Base de datos (PostgreSQL) ─────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mantenimientos
DB_USERNAME=postgres
DB_PASSWORD=

# ── Sesión / Caché / Cola ──────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ── Correo ─────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@tu-dominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Sanctum ────────────────────────────────────────────────────────────────────
# Dominio(s) del frontend separados por coma
SANCTUM_STATEFUL_DOMAINS=app.tu-dominio.com

# URL pública del frontend Next.js (usada en enlaces de correos)
FRONTEND_URL=https://app.tu-dominio.com

# ── Superadmin inicial (solo se usa en php artisan db:seed) ───────────────────
# Cambia estos valores ANTES de ejecutar el seeder en producción.
# El usuario tendrá must_change_password=true y deberá cambiar la contraseña al primer login.
SUPERADMIN_EMAIL=admin@tu-dominio.com
SUPERADMIN_PASSWORD=Cambiar@2025!
SUPERADMIN_NAME="Super Administrador"
